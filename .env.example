# Credenciais do Supabase. Copie para .env.local e preencha.
# Project Settings → API, no painel do Supabase.

# Públicas (vão pro frontend — OK serem expostas):
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# SECRETA — usada APENAS pelo script de seed (scripts/seed.mjs).
# Sem prefixo VITE_ de propósito: nunca é embutida no bundle do site.
# NUNCA commitar nem expor no frontend.
SUPABASE_SERVICE_ROLE_KEY=
